{
  "expo": {
    "name": "Savr",
    "slug": "savr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "savr",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.saver.savr"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.saver.savr",
      "backgroundColor": "#0F0F0F",
      "versionCode": 1,
      "targetSdkVersion": 35,
      "permissions": [
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F0F0F",
          "image": "./assets/icon.png",
          "imageWidth": 80
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "06661bbd-b3e6-4e14-8480-9d3cd0ecda34"
      }
    },
    "owner": "mwnswrang"
  }
}